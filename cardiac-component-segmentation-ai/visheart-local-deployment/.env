# ===================================# ========================================

# VisHeart Environment Configuration# VisHeart Local Development Environment

# ===================================# ========================================

# Copy this file to .env and customize as needed

# ===================================# DO NOT commit .env to version control

# Application Metadata

# ===================================# ========================================

APP_NAME=visheart# MinIO S3 (Local Storage)

APP_VERSION=1.0.0# ========================================

NODE_ENV=productionMINIO_ROOT_USER=minioadmin

MINIO_ROOT_PASSWORD=minioadmin123

# ===================================AWS_BUCKET_NAME=visheart-bucket

# Port Configuration

# ===================================# ========================================

FRONTEND_PORT=3000# MongoDB (Local Database)

BACKEND_PORT=5000# ========================================

GPU_PORT=8001MONGO_ROOT_USER=admin

MONGODB_PORT=27017MONGO_ROOT_PASSWORD=password123

REDIS_PORT=6379

MINIO_PORT=9000# ========================================

MINIO_CONSOLE_PORT=9001# Redis (Local Cache)

# ========================================

# ===================================REDIS_PASSWORD=redis123

# Frontend Configuration

# ===================================# ========================================

NEXT_PUBLIC_API_URL=http://localhost:5000# Backend Secrets

NEXT_PUBLIC_ENV=production# ========================================

SESSION_SECRET=local-session-secret-change-in-production

# ===================================GPU_SERVER_AUTH_JWT_SECRET=local-gpu-jwt-secret-change-in-production

# Backend ConfigurationADMIN_PASS=P@ssw0rd123!

# ===================================

PORT=5000# ========================================

CORS_ORIGIN=http://localhost:3000# GPU Server Credentials

# ========================================

# ===================================GPU_SERVER_USERNAME=admin

# Database Configuration (MongoDB)GPU_SERVER_PASSWORD=gpu-server-password

# ===================================

MONGODB_URI=mongodb://admin:P@ssw0rd123!@mongodb:27017/visheart?authSource=admin# ========================================

MONGO_INITDB_ROOT_USERNAME=admin# Application Environment

MONGO_INITDB_ROOT_PASSWORD=P@ssw0rd123!# ========================================

MONGO_INITDB_DATABASE=visheartNODE_ENV=development


# ===================================
# Redis Cache Configuration
# ===================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=RedisP@ssw0rd456!

# ===================================
# S3 Storage Configuration (MinIO)
# ===================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin123
S3_BUCKET_NAME=visheart-bucket
S3_ENDPOINT=http://minio:9000
S3_FORCE_PATH_STYLE=true
S3_USE_SSL=false

# MinIO Configuration
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_DEFAULT_BUCKETS=visheart-bucket

# ===================================
# GPU Inference Server Configuration
# ===================================
GPU_SERVER_URL=http://visheart-gpu:8001
GPU_API_KEY=your-secure-gpu-api-key-change-this
INFERENCE_TIMEOUT=300000

# ===================================
# Authentication Configuration
# ===================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
SESSION_SECRET=your-super-secret-session-key-change-this
ADMIN_USERNAME=admin
ADMIN_PASSWORD=P@ssw0rd123!

# ===================================
# Security Configuration
# ===================================
BCRYPT_ROUNDS=10
TOKEN_EXPIRATION=24h
REFRESH_TOKEN_EXPIRATION=7d

# ===================================
# Logging Configuration
# ===================================
LOG_LEVEL=info
LOG_DIR=./logs

# ===================================
# GPU/CUDA Configuration (Optional)
# ===================================
CUDA_VISIBLE_DEVICES=0
USE_GPU=true

# ===================================
# Performance Configuration
# ===================================
MAX_FILE_SIZE=500MB
MAX_UPLOAD_FILES=50
WORKER_THREADS=4

# ===================================
# Email Configuration (Optional)
# ===================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# EMAIL_FROM=noreply@visheart.com

# ===================================
# Development/Debug Configuration
# ===================================
DEBUG=false
VERBOSE_LOGGING=false

# Dependencies
**/node_modules
**/.pnp
**/.pnp.js

# Testing
**/coverage
**/__tests__
**/*.test.ts
**/*.test.js
**/*.spec.ts
**/*.spec.js

# Next.js
**/.next/
**/out/

# Build artifacts (will be rebuilt in Docker)
**/build
**/dist

# Misc
**/.DS_Store
**/*.pem

# Environment files (defined in docker-compose)
**/.env
**/.env.local
**/.env.development.local
**/.env.test.local
**/.env.production.local

# Debug logs
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/pnpm-debug.log*

# Local env files
**/.env*.local

# Vercel
**/.vercel

# TypeScript
**/*.tsbuildinfo
**/next-env.d.ts

# IDE
**/.idea
**/.vscode
**/*.swp
**/*.swo

# Git
**/.git
**/.gitignore
**/.gitattributes

# Docker
**/.dockerignore
**/Dockerfile
**/docker-compose*.yml

# CI/CD
**/.github
**/.gitlab-ci.yml

# Temporary directories
**/tmp
**/temp
**/temp_*
**/.cache

# OS files
**/.DS_Store
**/Thumbs.db

# Logs
**/logs
**/*.log

# Documentation (not needed in runtime)
**/README.md
**/CHANGELOG.md
**/LICENSE
**/docs

{
  "name": "cardiac_segmentation_fyp_server",
  "version": "1.0.0",
  "description": "This is a Node.js + Express.js Backend for the VisHeart Cardiac Segmentation Software Project for Team 6's FYP A.",
  "main": "index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "npx nodemon src/index.ts",
    "build": "tsc && cpx \"src/python/**/*\" dist/python",
    "test": "jest --runInBand --detectOpenHandles --forceExit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jamesmuking5/Cardiac_Segmentation_FYP_Server.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/jamesmuking5/Cardiac_Segmentation_FYP_Server/issues"
  },
  "homepage": "https://github.com/jamesmuking5/Cardiac_Segmentation_FYP_Server#readme",
  "nodemonConfig": {
    "watch": [
      "src"
    ],
    "ext": "ts,json",
    "ignore": [
      "temp_exports/*",
      "logs/*",
      "__tests__/*",
      "src/temp_upload/*",
      "src/temp_jpeg/*",
      "src/temp_mesh/*"
    ],
    "exec": "ts-node ./src/index.ts"
  },
  "dependencies": {
    "axios": "^1.11.0",
    "@aws-sdk/client-cloudwatch": "^3.913.0",
    "@aws-sdk/client-cost-explorer": "^3.916.0",
    "@aws-sdk/client-s3": "^3.873.0",
    "@aws-sdk/s3-request-presigner": "^3.873.0",
    "bcrypt": "^6.0.0",
    "connect-redis": "^9.0.0",
    "cors": "^2.8.5",
    "cronstrue": "^3.2.0",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "express-session": "^1.18.2",
    "express-validator": "^7.2.1",
    "form-data": "^4.0.4",
    "fs-extra": "^11.3.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "logform": "^2.7.0",
    "mongoose": "^8.18.0",
    "multer": "^2.0.2",
    "nifti-reader-js": "^0.8.0",
    "node-cron": "^4.2.1",
    "nodemon": "^3.1.10",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0",
    "redis": "^5.8.2",
    "supertest": "^7.1.4",
    "uuid": "^11.1.0",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.34.0",
    "@types/axios": "^0.14.4",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/express-session": "^1.18.2",
    "@types/fs-extra": "^11.0.4",
    "@types/helmet": "^4.0.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mongoose": "^5.11.97",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.3.0",
    "@types/node-cron": "^3.0.11",
    "@types/passport": "^1.0.17",
    "@types/passport-local": "^1.0.38",
    "@types/redis": "^4.0.11",
    "@types/supertest": "^6.0.3",
    "@types/tar": "^6.1.13",
    "@types/tough-cookie": "^4.0.5",
    "@typescript-eslint/eslint-plugin": "^8.41.0",
    "@typescript-eslint/parser": "^8.41.0",
    "axios-cookiejar-support": "^6.0.4",
    "cpx": "^1.5.0",
    "eslint": "^9.34.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "globals": "^16.3.0",
    "jest": "^30.0.5",
    "mongodb-memory-server": "^10.2.0",
    "prettier": "^3.6.2",
    "tough-cookie": "^6.0.0",
    "ts-jest": "^29.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.41.0"
  }
}
